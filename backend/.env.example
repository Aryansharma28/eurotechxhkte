# Copy to backend/.env and fill in real values (backend/.env is gitignored).

# Supabase project — server reads these (see src/lib/supabase.ts)
SUPABASE_URL=https://waeoxrhjrdiwknlokiai.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service-role key — used by getAdminClient() (family route) and the seed script.
# Bypasses RLS. Keep secret; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
PORT=3001

# Local dev escape hatch ONLY — disables TLS cert verification process-wide.
# Leave unset everywhere except a local machine with the schannel cert issue.
# ALLOW_INSECURE_TLS=1

# Backend secret — generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=replace-with-a-strong-random-secret
