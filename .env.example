# Google Gemini API key (for voice agent)
GEMINI_API_KEY=

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=   # E.164 format, e.g. +15551234567

# Target phone number for outbound calls
USER_PHONE_NUMBER=     # E.164 format, e.g. +15559876543

# Public tunnel URL (ngrok / localtunnel) so Twilio can reach this server
TUNNEL_URL=            # e.g. https://abc123.ngrok-free.app

# Supabase — the voice agent writes call outcomes here (DailyCall / ActivityRecord / Flag).
# Use the SERVICE ROLE key (server-side only, bypasses RLS). Same project as the dashboard.
SUPABASE_URL=https://waeoxrhjrdiwknlokiai.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Which elder a call logs against when it can't be resolved from the caller's number.
# Matches an elder slug seeded in Supabase: wong | chan | lee | cheung | ho
DEMO_ELDER_ID=wong

# Optional: override default port (default: 3000)
PORT=3000
