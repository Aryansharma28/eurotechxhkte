# Google Gemini API key (for voice agent)
GEMINI_API_KEY=

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=   # E.164 format, e.g. +15551234567

# Target phone number for outbound calls
USER_PHONE_NUMBER=     # E.164 format, e.g. +15559876543

# Public tunnel URL (ngrok / localtunnel) so Twilio can reach this server
TUNNEL_URL=            # e.g. https://abc123.ngrok-free.app

# Optional: override default port (default: 3000)
PORT=3000
